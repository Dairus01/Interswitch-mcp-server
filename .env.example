# Core credentials from Interswitch Developer Console
INTERSWITCH_CLIENT_ID=
INTERSWITCH_CLIENT_SECRET=

# sandbox | production. Defaults to sandbox.
INTERSWITCH_ENV=sandbox

# Safety controls
INTERSWITCH_READ_ONLY=false
INTERSWITCH_REQUIRE_CONFIRMATION=true

# Business identifiers
INTERSWITCH_MERCHANT_CODE=
INTERSWITCH_PAYABLE_CODE=
INTERSWITCH_INITIATING_ENTITY_CODE=
INTERSWITCH_TERMINAL_ID=

# Optional Card 360 credentials
CARD360_CLIENT_ID=
CARD360_CLIENT_SECRET=
CARD360_RSA_PUBLIC_KEY=

# Optional Transaction Search credentials
TRANSACTION_SEARCH_CLIENT_ID=
TRANSACTION_SEARCH_CLIENT_SECRET=

# Optional Agency Banking credentials
INTERSWITCH_AGENCY_MERCHANT_ID=
INTERSWITCH_AGENCY_TERMINAL_ID=

# Optional legacy InterswitchAuth support
INTERSWITCH_LEGACY_AUTH_ENABLED=false
